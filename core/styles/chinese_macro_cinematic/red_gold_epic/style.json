{
  "name": "red_gold_epic",
  "version": "1.0",
  "description": "Chinese cinematic macro-style. Bold red/gold palette, dramatic scale transitions, majestic pacing. Inspired by Chinese government presentations, epic documentaries, and national brand films.",
  "color_system": {
    "primary": "#C41E3A",
    "primary_light": "#E8455C",
    "primary_dark": "#8B0000",
    "accent": "#D4A843",
    "accent_light": "#F0D68A",
    "accent_dark": "#A07828",
    "surface_bg": "#FFFFFF",
    "surface_neutral": "#F8F5F0",
    "surface_dark": "#1A0A0A",
    "surface_mid": "#2C1515",
    "surface_glass": "rgba(255,255,255,0.06)",
    "surface_raised": "#FDFBF7",
    "surface_sunken": "#F0EBE0",
    "text_primary": "#1A1A1A",
    "text_secondary": "#5C4033",
    "text_tertiary": "#8B7355",
    "text_on_dark": "#F5F0E8",
    "text_on_dark_secondary": "rgba(245,240,232,0.72)",
    "text_on_brand": "#FFFFFF",
    "text_on_brand_secondary": "rgba(255,255,255,0.82)",
    "success": "#2E7D32",
    "warning": "#E65100",
    "danger": "#C62828",
    "info": "#1565C0",
    "glow": "rgba(212,168,67,0.18)",
    "shadow": "rgba(0,0,0,0.08)",
    "overlay_dark": "rgba(0,0,0,0.55)",
    "overlay_light": "rgba(255,255,255,0.12)"
  },
  "typography_system": {
    "title_font": "Noto Serif SC, Source Han Serif SC, SimSun, serif",
    "body_font": "Noto Sans SC, Source Han Sans SC, Microsoft YaHei, sans-serif",
    "mono_font": "Source Code Pro, monospace",
    "scale_micro": 10,
    "scale_caption": 12,
    "scale_body_sm": 14,
    "scale_body": 16,
    "scale_body_lg": 18,
    "scale_h3": 24,
    "scale_h2": 32,
    "scale_h1": 42,
    "scale_hero": 56,
    "scale_display": 72,
    "scale_mega": 96,
    "role_prescriptions": {
      "hook": {
        "title_scale": "mega",
        "title_weight": 900,
        "title_tracking": -0.01,
        "subtitle_scale": "h3",
        "subtitle_weight": 500,
        "body_scale": "body_lg",
        "body_weight": 400,
        "max_width_ch": 40,
        "line_height_title": 1.08,
        "line_height_body": 1.6,
        "word_limit": 8,
        "vertical_align": "center",
        "whitespace_ratio": 0.45
      },
      "conflict": {
        "title_scale": "hero",
        "title_weight": 900,
        "title_tracking": -0.005,
        "subtitle_scale": "h3",
        "subtitle_weight": 600,
        "body_scale": "body_lg",
        "body_weight": 500,
        "max_width_ch": 45,
        "line_height_title": 1.1,
        "line_height_body": 1.4,
        "word_limit": 50,
        "vertical_align": "top",
        "whitespace_ratio": 0.1
      },
      "escalation": {
        "title_scale": "display",
        "title_weight": 900,
        "title_tracking": -0.005,
        "subtitle_scale": "h2",
        "subtitle_weight": 600,
        "body_scale": "body_lg",
        "body_weight": 500,
        "max_width_ch": 42,
        "line_height_title": 1.05,
        "line_height_body": 1.35,
        "word_limit": 40,
        "vertical_align": "top",
        "whitespace_ratio": 0.08
      },
      "vision": {
        "title_scale": "display",
        "title_weight": 800,
        "title_tracking": -0.01,
        "subtitle_scale": "h3",
        "subtitle_weight": 400,
        "body_scale": "body_lg",
        "body_weight": 400,
        "max_width_ch": 42,
        "line_height_title": 1.12,
        "line_height_body": 1.6,
        "word_limit": 16,
        "vertical_align": "center",
        "whitespace_ratio": 0.4
      },
      "call_to_action": {
        "title_scale": "display",
        "title_weight": 900,
        "title_tracking": -0.015,
        "subtitle_scale": "h3",
        "subtitle_weight": 500,
        "body_scale": "body_lg",
        "body_weight": 600,
        "max_width_ch": 35,
        "line_height_title": 1.08,
        "line_height_body": 1.5,
        "word_limit": 8,
        "vertical_align": "center",
        "whitespace_ratio": 0.5
      },
      "breathing_page": {
        "title_scale": "h2",
        "title_weight": 300,
        "title_tracking": 0.01,
        "subtitle_scale": "body",
        "subtitle_weight": 300,
        "body_scale": "body_sm",
        "body_weight": 300,
        "max_width_ch": 50,
        "line_height_title": 1.5,
        "line_height_body": 1.8,
        "word_limit": 10,
        "vertical_align": "center",
        "whitespace_ratio": 0.7
      }
    }
  },
  "composition_system": {
    "container_class": {
      "hook": "fullscreen_hero",
      "context": "overview_grid",
      "evidence": "split_content",
      "insight": "reframe_panel",
      "conflict": "tension_split",
      "escalation": "intensify_stack",
      "release": "relief_spread",
      "vision": "horizon_canvas",
      "recap": "pillars_grid",
      "call_to_action": "focal_center",
      "breathing_page": "breathing_space"
    },
    "negative_space": {
      "hook": 0.45,
      "context": 0.2,
      "evidence": 0.15,
      "insight": 0.3,
      "conflict": 0.08,
      "escalation": 0.05,
      "release": 0.35,
      "vision": 0.4,
      "recap": 0.22,
      "call_to_action": 0.5,
      "breathing_page": 0.7
    },
    "asymmetry": {
      "hook": "symmetric",
      "context": "slight_left",
      "evidence": "left_weighted",
      "insight": "dynamic_shift",
      "conflict": "unbalanced",
      "escalation": "unbalanced",
      "release": "balanced",
      "vision": "symmetric",
      "recap": "balanced",
      "call_to_action": "symmetric",
      "breathing_page": "symmetric"
    }
  },
  "motion_language": {
    "default_easing": "cubic-bezier(0.25, 0, 0, 1)",
    "emphatic_easing": "cubic-bezier(0, 0.6, 0.2, 1)",
    "gentle_easing": "cubic-bezier(0.35, 0, 0.1, 1)",
    "snappy_easing": "cubic-bezier(0, 0, 0.15, 1)",
    "dramatic_easing": "cubic-bezier(0.2, 0, 0.9, 1)",
    "emotional_entrance": {
      "curious": {
        "type": "delayed_reveal",
        "stagger_ms": 180,
        "easing": "gentle",
        "scale_var": 0
      },
      "reflective": {
        "type": "slow_dissolve",
        "stagger_ms": 350,
        "easing": "gentle",
        "scale_var": 0
      },
      "confident": {
        "type": "strong_enter",
        "stagger_ms": 100,
        "easing": "snappy",
        "scale_var": 0.03
      },
      "inspired": {
        "type": "rising_reveal",
        "stagger_ms": 120,
        "easing": "emphatic",
        "scale_var": 0.06
      },
      "excited": {
        "type": "burst_reveal",
        "stagger_ms": 80,
        "easing": "emphatic",
        "scale_var": 0.08
      },
      "determined": {
        "type": "resolve_enter",
        "stagger_ms": 80,
        "easing": "snappy",
        "scale_var": 0.04
      },
      "shocked": {
        "type": "impact_reveal",
        "stagger_ms": 50,
        "easing": "dramatic",
        "scale_var": 0.1
      },
      "solemn": {
        "type": "respectful_fade",
        "stagger_ms": 400,
        "easing": "gentle",
        "scale_var": 0
      },
      "engaged": {
        "type": "active_reveal",
        "stagger_ms": 120,
        "easing": "default",
        "scale_var": 0.02
      }
    },
    "intensity_speed": {
      "1": {
        "duration_mult": 1.2,
        "stagger_mult": 1.8
      },
      "2": {
        "duration_mult": 0.9,
        "stagger_mult": 1.3
      },
      "3": {
        "duration_mult": 0.65,
        "stagger_mult": 0.9
      },
      "4": {
        "duration_mult": 0.4,
        "stagger_mult": 0.55
      },
      "5": {
        "duration_mult": 0.2,
        "stagger_mult": 0.35
      }
    }
  },
  "surface_system": {
    "surfaces": {
      "hook": {
        "background": "brand_gradient",
        "text_color": "text_on_brand",
        "text_secondary": "text_on_brand_secondary",
        "ambient": "glow",
        "accent_glow": true
      },
      "conflict": {
        "background": "tension_gradient",
        "text_color": "text_on_dark",
        "text_secondary": "text_on_dark_secondary",
        "ambient": "none",
        "accent_glow": false
      },
      "escalation": {
        "background": "dark_gradient",
        "text_color": "text_on_dark",
        "text_secondary": "text_on_dark_secondary",
        "ambient": "none",
        "accent_glow": true
      },
      "vision": {
        "background": "horizon_gradient",
        "text_color": "text_primary",
        "text_secondary": "text_tertiary",
        "ambient": "glow",
        "accent_glow": true
      },
      "call_to_action": {
        "background": "brand_gradient",
        "text_color": "text_on_brand",
        "text_secondary": "text_on_brand_secondary",
        "ambient": "glow",
        "accent_glow": true
      }
    },
    "background_css": {
      "brand_gradient": "linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 60%, var(--c-accent-dark) 100%)",
      "dark_gradient": "linear-gradient(170deg, #1A0A0A 0%, var(--c-surface-mid) 40%, var(--c-primary-dark) 100%)",
      "tension_gradient": "linear-gradient(160deg, #1A0A0A 0%, var(--c-surface-mid) 50%, var(--c-primary-dark) 100%)",
      "horizon_gradient": "linear-gradient(180deg, var(--c-surface-bg) 0%, color-mix(in srgb, var(--c-accent) 10%, var(--c-surface-bg)) 50%, color-mix(in srgb, var(--c-primary) 8%, var(--c-surface-bg)) 100%)",
      "surface_bg": "var(--c-surface-bg)",
      "surface_neutral": "linear-gradient(180deg, var(--c-surface-neutral) 0%, var(--c-surface-bg) 100%)"
    }
  },
  "transition_language": {
    "default_easing": "cubic-bezier(0.2, 0, 0, 1)",
    "relation_transitions": {
      "progression": {
        "type": "slide_fade",
        "duration_ms": 400,
        "easing": "cubic-bezier(0.2, 0, 0, 1)"
      },
      "contrast": {
        "type": "hard_cut",
        "duration_ms": 100,
        "easing": "step-end"
      },
      "escalation": {
        "type": "intensify",
        "duration_ms": 200,
        "easing": "cubic-bezier(0.2, 0, 0.9, 1)"
      },
      "pivot": {
        "type": "swing_pivot",
        "duration_ms": 500,
        "easing": "cubic-bezier(0.5, 0, 0.3, 1)"
      },
      "emotional_shift": {
        "type": "color_shift",
        "duration_ms": 500,
        "easing": "cubic-bezier(0.35, 0, 0.1, 1)"
      }
    }
  },
  "spacing_system": {
    "unit_px": 8,
    "slide_padding_v": "5vh",
    "slide_padding_h": "5vw",
    "content_gap": "0.4em"
  },
  "density_system": {
    "levels": {
      "1": {
        "max_points": 2,
        "max_chars_per_point": 45,
        "max_total_chars": 60
      },
      "2": {
        "max_points": 3,
        "max_chars_per_point": 65,
        "max_total_chars": 140
      },
      "3": {
        "max_points": 5,
        "max_chars_per_point": 85,
        "max_total_chars": 250
      },
      "4": {
        "max_points": 6,
        "max_chars_per_point": 95,
        "max_total_chars": 350
      },
      "5": {
        "max_points": 8,
        "max_chars_per_point": 110,
        "max_total_chars": 500
      }
    }
  },
  "cinematic_rhythm": {
    "act_pacing": {
      "opening": {
        "pace": "slow",
        "intensity_baseline": 3,
        "transition_spacing": "generous"
      },
      "climax": {
        "pace": "fast",
        "intensity_baseline": 5,
        "transition_spacing": "tight"
      },
      "closing": {
        "pace": "slow",
        "intensity_baseline": 5,
        "transition_spacing": "generous"
      }
    },
    "tension_curve": [
      {
        "position_pct": 0,
        "intensity": 4
      },
      {
        "position_pct": 10,
        "intensity": 2
      },
      {
        "position_pct": 35,
        "intensity": 3
      },
      {
        "position_pct": 55,
        "intensity": 5
      },
      {
        "position_pct": 70,
        "intensity": 5
      },
      {
        "position_pct": 85,
        "intensity": 3
      },
      {
        "position_pct": 100,
        "intensity": 5
      }
    ]
  },
  "emotional_mapping": {
    "kinetic_typography": {
      "inspired": {
        "emphasis_delay": 0.3,
        "emphasis_easing": "emphatic",
        "weight_keywords": true
      },
      "confident": {
        "emphasis_delay": 0.2,
        "emphasis_easing": "snappy",
        "weight_keywords": true
      },
      "determined": {
        "emphasis_delay": 0.15,
        "emphasis_easing": "snappy",
        "weight_keywords": true
      },
      "excited": {
        "emphasis_delay": 0.1,
        "emphasis_easing": "emphatic",
        "weight_keywords": true
      },
      "solemn": {
        "emphasis_delay": 0.8,
        "emphasis_easing": "gentle",
        "weight_keywords": false
      },
      "shocked": {
        "emphasis_delay": 0.08,
        "emphasis_easing": "dramatic",
        "weight_keywords": true
      }
    }
  },
  "metadata": {
    "author": "Style OS",
    "tags": [
      "chinese",
      "macro",
      "bold",
      "dramatic",
      "majestic",
      "cinematic"
    ],
    "best_for": [
      "government_briefings",
      "national_brand_films",
      "large_venue_keynotes",
      "strategic_announcements"
    ],
    "avoid_for": [
      "casual_meetings",
